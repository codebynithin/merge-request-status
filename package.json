{
  "name": "merge-request-status",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Client-only React app to track GitLab merge requests hierarchically by target branch",
  "scripts": {
    "dev": "vite",
    "start:dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host --port 5173",
    "start": "npm run build && npm run preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sass": "^1.79.4",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
